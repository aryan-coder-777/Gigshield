APP_NAME=GigShield
DEBUG=True
SECRET_KEY=gigshield-super-secret-jwt-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DATABASE_URL is optional. If omitted, GigShield uses a temp-directory SQLite DB.

# Optional real APIs (leave empty to use mock data)
OWM_API_KEY=
WAQI_TOKEN=

# Optional Razorpay test keys (leave empty for mock payouts)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Fraud detection threshold (-0.1 = strict, -0.3 = lenient)
FRAUD_THRESHOLD=-0.15

# Trigger monitor interval (seconds)
TRIGGER_POLL_INTERVAL=900
