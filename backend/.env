APP_NAME=GigShield
DEBUG=True
SECRET_KEY=gigshield-super-secret-jwt-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Default: SQLite stored in backend/ (zero config, works immediately)
# DATABASE_URL=sqlite+aiosqlite:///./gigshield.db
#
# To use PostgreSQL instead:
# 1. Install PostgreSQL and create a database: CREATE DATABASE gigshield;
# 2. Uncomment and fill in the line below:
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/gigshield
#
# pip install asyncpg is already in requirements.txt

# ── REAL WEATHER API (optional — mock data used if blank) ────────────────────
# OpenWeatherMap free tier: https://openweathermap.org/api
OWM_API_KEY=

# ── REAL AQI API (optional — mock data used if blank) ────────────────────────
# WAQI (World Air Quality Index) token: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# ── RAZORPAY PAYMENT RAIL (optional — mock payouts if blank) ─────────────────
# Test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── STRIPE PAYMENT RAIL (optional — mock payment intents if blank) ───────────
# Test key from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# ── AI / ML SETTINGS ─────────────────────────────────────────────────────────
# Isolation Forest fraud score threshold
# Range: -0.10 (very strict, more BLOCKED) to -0.30 (lenient, more TRUSTED)
FRAUD_THRESHOLD=-0.15

# Set to True to retrain ML models on next startup (useful after model changes)
FORCE_RETRAIN_MODELS=False

# ── SCHEDULER ─────────────────────────────────────────────────────────────────
# How often trigger monitor polls all zones (seconds). 900 = 15 minutes
TRIGGER_POLL_INTERVAL=900
