# ========================================
# GigShield Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual API keys

# ──── API KEYS (CRITICAL FOR AI CHAT) ──────────────────────────────────────
# Get your Gemini API key from: https://ai.google.dev/
# 1. Go to https://ai.google.dev/
# 2. Click "Get API Key" 
# 3. Create or select a Google Cloud project
# 4. Copy the key and paste below
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Weather & Air Quality APIs (for trigger detection)
# OpenWeatherMap - Get from: https://openweathermap.org/api
OWM_API_KEY=

# World Air Quality Index - Get from: https://waqi.info/api-doc/
WAQI_TOKEN=

# ──── PAYMENT GATEWAYS (Optional) ──────────────────────────────────────────
# Razorpay - Get from: https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe - Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ──── DATABASE ──────────────────────────────────────────────────────────────
# Leave empty for SQLite (default - requires 0 setup)
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/gigshield
DATABASE_URL=

# ──── APPLICATION SETTINGS ──────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=gigshield-super-secret-jwt-key-change-in-production-2024
TRIGGER_POLL_INTERVAL=900
FRAUD_THRESHOLD=-0.15
FORCE_RETRAIN_MODELS=False
